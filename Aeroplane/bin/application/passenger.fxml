<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane id="AnchorPane" prefHeight="600.0" prefWidth="900.0" stylesheets="@PassengerDetails.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="application.passengerController">
   <children>
      <ImageView fitHeight="600.0" fitWidth="900.0">
         <image>
            <Image url="@92.jpg" />
         </image>
      </ImageView>
      <Label fx:id="PassengerDetailsLabel" layoutX="277.0" layoutY="17.0" text="Passenger Details Module" textFill="#ffaf01">
         <font>
            <Font name="System Bold" size="34.0" />
         </font>
      </Label>
      <TableView fx:id="passengerTable" layoutX="48.0" layoutY="87.0" prefHeight="439.0" prefWidth="802.0">
        <columns>
          <TableColumn fx:id="usernameColumn" prefWidth="84.0" text="Name" />
            <TableColumn fx:id="passengerNumberColumn" prefWidth="94.39996337890625" text="Phone No." />
            <TableColumn fx:id="nationalityColumn" prefWidth="70.4000244140625" text="Nationality" />
            <TableColumn fx:id="passportNumberColumn" prefWidth="92.0" text="Passport No." />
            <TableColumn fx:id="flightCodeColumn" prefWidth="92.800048828125" text="Flight Code" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
      <Button fx:id="close" layoutX="410.0" layoutY="536.0" mnemonicParsing="false" onAction="#closet" prefHeight="37.0" prefWidth="80.0" style="-fx-background-color: white;" text="Close">
         <font>
            <Font name="System Bold" size="14.0" />
         </font>
      </Button>
      <ImageView fitHeight="84.0" fitWidth="100.0" layoutX="193.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@logo.png" />
         </image>
      </ImageView>
   </children>
</AnchorPane>
