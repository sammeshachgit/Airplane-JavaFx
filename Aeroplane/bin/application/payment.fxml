<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane id="AnchorPane" prefHeight="600.0" prefWidth="900.0" stylesheets="@PaymentDetaills.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="application.paymentController">
   <children>
      <ImageView fitHeight="600.0" fitWidth="900.0" layoutY="-1.0">
         <image>
            <Image url="@92.jpg" />
         </image>
      </ImageView>
      <Label fx:id="PaymentDetailsLabel" layoutX="280.0" layoutY="5.0" text="Payment Details Module" textFill="#ff9500">
         <font>
            <Font name="System Bold" size="34.0" />
         </font>
      </Label>
      <TableView fx:id="PaymentDetailsTable" layoutX="56.0" layoutY="74.0" prefHeight="462.0" prefWidth="796.0">
         <columns>
            <TableColumn fx:id="USERNAME" prefWidth="89.60003662109375" text="User Name" />
            <TableColumn fx:id="FLIGHTCODE" prefWidth="84.0" text="Flight Code" />
            <TableColumn fx:id="CARDNO" prefWidth="94.39996337890625" text="Card No." />
            <TableColumn fx:id="AMOUNT" prefWidth="92.0" text="Amount Paid" />
            <TableColumn fx:id="PAYDATE" prefWidth="92.800048828125" text="Payment Date" />
         </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
      <Button fx:id="close" layoutX="414.0" layoutY="547.0" mnemonicParsing="false" onAction="#closet" prefHeight="38.0" prefWidth="72.0" style="-fx-background-color: white;" text="Close">
         <font>
            <Font size="14.0" />
         </font>
      </Button>
      <ImageView fitHeight="88.0" fitWidth="96.0" layoutX="185.0" layoutY="-14.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@logo.png" />
         </image>
      </ImageView>
   </children>
</AnchorPane>
