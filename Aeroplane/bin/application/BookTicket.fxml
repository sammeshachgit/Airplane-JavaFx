<AnchorPane id="AnchorPane" prefHeight="600.0" prefWidth="900.0" stylesheets="@BookTicket.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="application.BookTicketController">
